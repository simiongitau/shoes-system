{
  "name": "nextjs-starter-spree",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001 --turbopack",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:locales": "tsx scripts/check-locale-parity.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "e2e:up": "docker compose -f e2e-backend/docker-compose.yml up -d --wait && ./scripts/e2e/bootstrap-spree.sh",
    "e2e:down": "docker compose -f e2e-backend/docker-compose.yml down -v"
  },
  "dependencies": {
    "@adyen/adyen-web": "^6.40.2",
    "@next/third-parties": "^16.2.10",
    "@paypal/react-paypal-js": "^10.1.2",
    "@sentry/nextjs": "^10.65.0",
    "@spree/sdk": "^1.1.0",
    "@stripe/react-stripe-js": "^6.7.0",
    "@stripe/stripe-js": "^9.9.0",
    "@swc/helpers": "^0.5.21",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "next": "^16",
    "next-intl": "^4.13.2",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.2",
    "react": "^19",
    "react-dom": "^19",
    "react-email": "^6.7.0",
    "react-svg-credit-card-payment-icons": "^6.0.4",
    "resend": "^6.17.2",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "swiper": "^14.0.5",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "overrides": {
    "minimatch": "^10.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@playwright/test": "^1.61.1",
    "@spree/cli": "^2.3.9",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.10",
    "tailwindcss": "^4",
    "tsx": "^4.23.0",
    "typescript": "^7",
    "vitest": "^4.1.10"
  }
}
